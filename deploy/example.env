# Copy to .env in THIS directory (next to docker-compose.yml), then adjust.
# NEVER commit real secrets — .env is gitignored.

# --- General ---
COMPOSE_PROJECT_NAME=ark
ARK_SERVER_VOLUME=ark-data

# --- Session / Map ---
SESSION_NAME=My ARK SE Server
SERVER_MAP=TheIsland
MAX_PLAYERS=2

# --- Secrets (must change) ---
# SERVER_PASSWORD is the join password: the ARK client only accepts letters + digits,
# max 24 characters (no special chars). ADMIN_PASSWORD is for RCON/admin, not entered on
# join, but keep it alphanumeric too to avoid shell/compose quoting issues.
SERVER_PASSWORD=change-me
ADMIN_PASSWORD=change-me-too

# --- Lifecycle ---
UPDATE_ON_START=true
BACKUP_ON_STOP=false
PRE_UPDATE_BACKUP=true
WARN_ON_STOP=true

# --- Launch flags ---
# BattlEye anti-cheat is ON by default. Set true to disable it (server launches with
# -NoBattlEye). Note: this is a launch flag, NOT a GameUserSettings.ini setting.
DISABLE_BATTLEYE=false
# Epic<->Steam crossplay (-crossplay).
ENABLE_CROSSPLAY=false

# --- Permissions / Resources ---
# PUID/PGID must match the host user owning the volume/bind mount; UMASK affects new files.
PUID=1000
PGID=1000
UMASK=0002
# RAM cap for the container (#85). Keep >=12g — ARK SE livelocks below ~10g even on
# TheIsland; raise for big maps/many mods. See ../arkserver-ops/docs/hardware-requirements.md.
MEM_LIMIT=12g

# --- Mods (optional, comma-separated Workshop IDs) ---
GAME_MOD_IDS=
# Workshop ID of a MAP mod (mod map instead of a stock map). Empty = stock map.
SERVER_MAP_MOD_ID=

# --- Cluster (opt-in) — leave empty for a plain vanilla server. ---
# See ../arkserver-ops/docs/mods-and-cluster.md for topologies and port offsets.
CLUSTER_ID=
SUB_INSTANCE_KEYS=
