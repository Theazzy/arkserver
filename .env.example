# .env.example — full variable reference.
# Copy to .env and set values. NEVER commit real secrets (.env is gitignored).
# The compose stack reads the .env next to deploy/docker-compose.yml; when running
# from ./deploy, copy this file (or deploy/example.env) to deploy/.env.

# --- General ---
COMPOSE_PROJECT_NAME=ark
ARK_SERVER_VOLUME=ark-data

# --- Session / Map ---
SESSION_NAME=My ARK SE Server
SERVER_MAP=TheIsland
MAX_PLAYERS=2

# --- Secrets (must change) ---
# SERVER_PASSWORD (join password): letters + digits only, max 24 chars (ARK client limit).
# ADMIN_PASSWORD (RCON/admin): keep alphanumeric to avoid quoting issues.
SERVER_PASSWORD=change-me
ADMIN_PASSWORD=change-me-too

# --- Lifecycle ---
UPDATE_ON_START=true
BACKUP_ON_STOP=false
PRE_UPDATE_BACKUP=true
WARN_ON_STOP=true

# --- Launch flags ---
# BattlEye is ON by default; set true to disable (-NoBattlEye). Launch flag, not an .ini setting.
DISABLE_BATTLEYE=false
ENABLE_CROSSPLAY=false

# --- Permissions / Resources ---
PUID=1000
PGID=1000
UMASK=0002
# Keep >=12g — ARK SE livelocks below ~10g. See arkserver-ops/server/docs/hardware-requirements.md.
MEM_LIMIT=12g

# --- Mods (optional, comma-separated Workshop IDs) ---
GAME_MOD_IDS=
SERVER_MAP_MOD_ID=

# --- Cluster (opt-in) — leave empty for a plain vanilla server. ---
# See arkserver-ops/server/docs/mods-and-cluster.md.
CLUSTER_ID=
SUB_INSTANCE_KEYS=
